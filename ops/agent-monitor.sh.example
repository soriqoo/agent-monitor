#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_LOG_LINES="${LOG_LINES:-100}"

default_repo_dir() {
  if [[ -f "$SCRIPT_DIR/docker-compose.yml" ]]; then
    echo "$SCRIPT_DIR"
    return
  fi

  if [[ -f "$SCRIPT_DIR/../repo/docker-compose.yml" ]]; then
    echo "$(cd "$SCRIPT_DIR/../repo" && pwd)"
    return
  fi

  echo "$SCRIPT_DIR"
}

default_env_file() {
  if [[ -f "$SCRIPT_DIR/.env" ]]; then
    echo "$SCRIPT_DIR/.env"
    return
  fi

  if [[ -f "$SCRIPT_DIR/../runtime/.env" ]]; then
    echo "$(cd "$SCRIPT_DIR/../runtime" && pwd)/.env"
    return
  fi

  echo "$SCRIPT_DIR/.env"
}

REPO_DIR="${REPO_DIR:-$(default_repo_dir)}"
ENV_FILE="${ENV_FILE:-$(default_env_file)}"

load_env_file() {
  if [[ -f "$ENV_FILE" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "$ENV_FILE"
    set +a
  fi
}

require_env_file() {
  if [[ ! -f "$ENV_FILE" ]]; then
    echo "Missing env file: $ENV_FILE" >&2
    echo "Place runtime/.env next to this script or override ENV_FILE." >&2
    exit 1
  fi
}

require_repo_dir() {
  if [[ ! -f "$REPO_DIR/docker-compose.yml" ]]; then
    echo "Missing docker-compose.yml under repo dir: $REPO_DIR" >&2
    echo "Supported layouts:" >&2
    echo "  1) runtime/agent-monitor.sh next to runtime/.env" >&2
    echo "  2) repo/agent-monitor.sh with repo/../runtime/.env" >&2
    echo "Or override REPO_DIR explicitly." >&2
    exit 1
  fi
}

compose() {
  require_env_file
  require_repo_dir
  (
    cd "$REPO_DIR"
    docker compose --env-file "$ENV_FILE" "$@"
  )
}

compose_demo() {
  require_env_file
  require_repo_dir
  (
    cd "$REPO_DIR"
    docker compose --env-file "$ENV_FILE" -f docker-compose.yml -f docker-compose.demo.yml "$@"
  )
}

app_port() {
  echo "${AGENT_MONITOR_PORT:-18080}"
}

app_url() {
  echo "http://127.0.0.1:$(app_port)"
}

dummy_service_url() {
  echo "http://127.0.0.1:${DUMMY_SERVICE_PORT:-18081}"
}

print_help() {
  cat <<'EOF'
Usage:
  ./agent-monitor.sh <command>

Commands:
  help        Show this help message
  sync        Fetch origin, switch to main, and reset to origin/main
  version     Show local HEAD, tracked origin/main, and divergence
  deploy      Rebuild and recreate the docker compose stack
  deploy-demo Start the stack with the dummy monitored service example
  ps          Show compose service status
  ps-demo     Show compose service status including demo services
  logs        Show recent agent-monitor logs
  logs-demo   Show recent dummy monitored service logs
  demo-mode   Get or change the dummy service runtime scenario
  logs-follow Follow agent-monitor logs
  health      Call /actuator/health
  summary     Call /internal/monitoring/summary
  status      Show ps, health, and summary together

Environment:
  ENV_FILE    Override the runtime env file path
  REPO_DIR    Override the checked-out repository path
  LOG_LINES   Override the default log tail size for logs
  DUMMY_SERVICE_PORT Override the localhost demo control port (default: 18081)

Path resolution:
  - if the script is placed under runtime/, it uses ../repo and ./.env
  - if the script is placed under repo/, it uses ./docker-compose.yml and ../runtime/.env
EOF
}

print_repo_commit_line() {
  local label="$1"
  local ref="$2"

  if ! git rev-parse --verify "$ref" >/dev/null 2>&1; then
    printf "%-14s %s\n" "$label" "(missing)"
    return
  fi

  local sha
  local subject
  sha="$(git rev-parse --short "$ref")"
  subject="$(git log -1 --pretty=%s "$ref")"

  printf "%-14s %s %s\n" "$label" "$sha" "$subject"
}

print_repo_version_report() {
  local ahead="?"
  local behind="?"
  local worktree_state="clean"

  if git rev-parse --verify origin/main >/dev/null 2>&1; then
    local counts
    counts="$(git rev-list --left-right --count HEAD...origin/main)"
    read -r ahead behind <<<"$counts"
  fi

  if [[ -n "$(git status --short)" ]]; then
    worktree_state="dirty"
  fi

  print_repo_commit_line "Local HEAD" "HEAD"
  print_repo_commit_line "Remote main" "origin/main"
  printf "%-14s ahead=%s behind=%s\n" "Divergence" "$ahead" "$behind"
  printf "%-14s %s\n" "Worktree" "$worktree_state"
}

run_sync() {
  require_repo_dir
  (
    cd "$REPO_DIR"
    local before_sha
    local after_sha
    before_sha="$(git rev-parse --short HEAD)"
    git fetch origin --prune
    git switch main
    git reset --hard origin/main
    after_sha="$(git rev-parse --short HEAD)"
    print_repo_version_report
    echo
    if [[ "$before_sha" != "$after_sha" ]]; then
      echo "Repository updated from $before_sha to $after_sha."
      echo "Run ./agent-monitor.sh deploy to apply the new version."
    else
      echo "Repository already matched origin/main."
      echo "Deploy is only needed if the running stack has not been refreshed yet."
    fi
  )
}

run_version() {
  require_repo_dir
  (
    cd "$REPO_DIR"
    print_repo_version_report
  )
}

run_deploy() {
  load_env_file
  compose up -d --build --force-recreate
}

run_deploy_demo() {
  load_env_file
  compose_demo up -d --build --force-recreate
}

run_ps() {
  compose ps
}

run_ps_demo() {
  compose_demo ps
}

run_logs() {
  compose logs --tail "$DEFAULT_LOG_LINES" agent-monitor
}

run_logs_demo() {
  compose_demo logs --tail "$DEFAULT_LOG_LINES" dummy-monitored-service
}

run_demo_mode() {
  load_env_file
  local scenario="${1:-status}"

  case "$scenario" in
    status)
      curl -fsS "$(dummy_service_url)/internal/test-control"
      ;;
    healthy|last-run-unavailable|health-down|run-failed|reset)
      curl -fsS -X PUT "$(dummy_service_url)/internal/test-control/$scenario"
      ;;
    *)
      echo "Unsupported demo scenario: $scenario" >&2
      echo "Supported: status, healthy, last-run-unavailable, health-down, run-failed, reset" >&2
      exit 1
      ;;
  esac
  echo
}

run_logs_follow() {
  compose logs -f agent-monitor
}

run_health() {
  load_env_file
  curl -fsS "$(app_url)/actuator/health"
  echo
}

run_summary() {
  load_env_file
  curl -fsS "$(app_url)/internal/monitoring/summary"
  echo
}

run_status() {
  run_ps
  run_health
  run_summary
}

main() {
  local command="${1:-help}"

  case "$command" in
    help|-h|--help)
      print_help
      ;;
    sync)
      run_sync
      ;;
    version)
      run_version
      ;;
    deploy)
      run_deploy
      ;;
    deploy-demo)
      run_deploy_demo
      ;;
    ps)
      run_ps
      ;;
    ps-demo)
      run_ps_demo
      ;;
    logs)
      run_logs
      ;;
    logs-demo)
      run_logs_demo
      ;;
    demo-mode)
      run_demo_mode "${2:-status}"
      ;;
    logs-follow)
      run_logs_follow
      ;;
    health)
      run_health
      ;;
    summary)
      run_summary
      ;;
    status)
      run_status
      ;;
    *)
      echo "Unknown command: $command" >&2
      echo >&2
      print_help
      exit 1
      ;;
  esac
}

main "$@"
